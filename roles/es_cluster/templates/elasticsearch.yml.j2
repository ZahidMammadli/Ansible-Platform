cluster.name: {{ es_cluster_name }}

node.name: "{{ es_node_name }}"
path.data: /var/lib/elasticsearch
path.logs: /var/log/elasticsearch

network.host: ["_local_", "{{ ansible_host }}"]
network.publish_host: "{{ ansible_host }}"
http.host: 0.0.0.0

discovery.seed_hosts:
{% for seed in es_discovery_seeds %}
  - "{{ seed }}"
{% endfor %}

{% if inventory_hostname == groups['es_nodes'][0] %}
cluster.initial_master_nodes:
{% for host in groups['es_nodes'] %}
  - "{{ hostvars[host].es_node_name }}"
{% endfor %}
{% endif %}

xpack.security.enabled: true

# HTTP TLS
xpack.security.http.ssl:
  enabled: false

# Transport TLS
xpack.security.transport.ssl:
  enabled: true
  verification_mode: certificate
  certificate_authorities: ["/etc/elasticsearch/certs/ca/ca.crt"]
  certificate: "/etc/elasticsearch/certs/{{ es_node_name }}/{{ es_node_name }}.crt"
  key: "/etc/elasticsearch/certs/{{ es_node_name }}/{{ es_node_name }}.key"

